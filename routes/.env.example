# Kopiraj to datoteko v .env in nastavi vrednosti
# cp .env.example .env

# Obvezno: dolg naključni niz
# Ustvari ga z: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=zamenjaj-z-naklucnim-nizom-vsaj-32-znakov

# Začetno geslo admin računa (privzeto admin/Admin123! — OBVEZNO zamenjaj)
ADMIN_PASSWORD=ZamenjajGeslo123!

# ── Shranjevanje podatkov ───────────────────────────────────────────────
# Na Renderju z diskom: nastavi DATA_DIR na priklopno pot diska.
# Baza (SQLite) se bo shranjevala tam in bo trajna.
DATA_DIR=/var/data

# Za lokalni razvoj lahko DATA_DIR pustiš prazno — baza bo v mapi projekta.

# (Neobvezno) Če bi raje uporabljal PostgreSQL namesto SQLite na disku,
# nastavi DATABASE_URL. Takrat DATA_DIR ni potreben.
# DATABASE_URL=postgresql://user:geslo@host:5432/narocilnice
